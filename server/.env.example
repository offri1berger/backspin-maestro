DATABASE_URL=postgresql://backspin_maestro:backspin_maestro@localhost:5432/backspin_maestro
REDIS_URL=redis://localhost:6379
CLIENT_URL=http://localhost:5173
PORT=8080

# Optional. Leave unset to disable /metrics (route returns 503).
# Set to a long random string; scrapers send `Authorization: Bearer <token>`.
METRICS_TOKEN=

# Optional. Pino level: trace|debug|info|warn|error|fatal. Defaults to
# 'info' in production, 'debug' otherwise.
LOG_LEVEL=
